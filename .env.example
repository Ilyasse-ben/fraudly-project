# ==============================================================================
# .env.example
# Copy this file to '.env' and fill in the values before starting the services.
# ==============================================================================

# --- Global Discovery ---
EUREKA_ZONE=http://discovery-service:8761/eureka/

# --- Database ---
DB_USER=postgres
DB_PASSWORD=your_secure_db_password
# Database URLs (Internal Docker Network)
DB_URL_AUTH=jdbc:postgresql://pgdb:5432/fraudly_auth
DB_URL_ASSESSMENT=jdbc:postgresql://pgdb:5432/fraudly_assessment
DB_URL_LEARNING=jdbc:postgresql://pgdb:5432/fraudly_learning
DB_URL_PROCTORING=jdbc:postgresql://pgdb:5432/fraudly_proctoring
DB_URL_ANALYTICS=jdbc:postgresql://pgdb:5432/fraudly_analytics

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_AUTO_OFFSET_RESET=earliest
# Topics
KAFKA_TOPIC_AI_RESULTS=ai_results
KAFKA_TOPIC_CORRECTION=exam.correction.requested
KAFKA_TOPIC_SCORED=exam.scored
KAFKA_TOPIC_COLLUSION_SUSPECTED=proctor.collusion_suspected
KAFKA_TOPIC_TUTOR_INTERACTION=tutor.interaction_logged
KAFKA_TOPIC_STUDENT_PROGRESS=student.progress_updated
# Consumer Groups
KAFKA_CONSUMER_GROUP_LEARNING=fraudly-learning-service
KAFKA_CONSUMER_GROUP_ANALYTICS=fraudly-analytics-service
KAFKA_GROUP_ID=fraudly-proctoring-service

# --- Security & JWT ---
# Generate a new random base64 string for production
JWT_SECRET=replace_with_a_secure_base64_string
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
INTERNAL_API_SECRET=replace_with_a_secure_internal_api_secret

# --- Service URLs & Redis/AI ---
AUTH_SERVICE_URL=http://authentification-service:8081
AI_SERVICE_URL=http://backend-ia:8000
REDIS_HOST=redis
REDIS_PORT=6379

# --- AWS (Required for S3) ---
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_SESSION_TOKEN=your_aws_session_token
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_s3_bucket_name

# --- Server Ports ---
SERVER_PORT=8080
SERVER_PORT_AUTH=8081
SERVER_PORT_ASSESSMENT=8082
SERVER_PORT_ANALYTICS=8084
SERVER_PORT_LEARNING=8083
SERVER_PORT_PROCTORING=8085